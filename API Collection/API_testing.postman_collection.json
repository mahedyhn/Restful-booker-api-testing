      "name": "GetBookingIds",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Check the status code is 200\", function (){\r",
              "    pm.expect(pm.response.code).to.eql(200);\r",
              "})\r",
              "\r",
              "pm.test(\"check the response time is less than 200ms\", function (){\r",
              "    pm.expect(pm.response.responseTime).to.be.below(200)\r",
              "})\r",
              "\r",
              "pm.test(\"Check the size of the file size\",function(){\r",
              "    pm.expect(pm.response.responseSize).to.be.below(100000)\r",
              "})\r",
              "\r",
              "pm.test(\"verify the response data format is json\",function(){\r",
              "    pm.response.to.have.jsonBody();\r",
              "})\r",
              "\r",
              "var responseBody = pm.response.json();\r",
              "pm.test(\"verify the 78 is exist or not\", function(){\r",
              "    var exists = responseBody.some(item=> item.bookingid === 78);\r",
              "    pm.expect(exists).to.be.true;\r",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
