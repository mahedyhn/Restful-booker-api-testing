    {
      "name": "CreateBooking",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var firstName = pm.variables.replaceIn('{{$randomFirstName}}');\r",
              "console.log(firstName);\r",
              "pm.environment.set('fName',firstName);\r",
              "\r",
              "var lastName = pm.variables.replaceIn('{{$randomLastName}}');\r",
              "pm.environment.set('lName',lastName);\r",
              "\r",
              "var totalPrice = pm.variables.replaceIn('{{$randomInt}}');\r",
              "pm.environment.set('tPrice',totalPrice);\r",
              "\r",
              "var depositPaid = pm.variables.replaceIn('{{$randomBoolean}}');\r",
              "pm.environment.set('dPaid',depositPaid);\r",
              "\r",
              "var checkIn = require('moment')().format('YYYY-MM-DD');\r",
              "pm.environment.set('checkIn',checkIn);\r",
              "\r",
              "var checkOut = require('moment')().add(5, 'd').format('YYYY-MM-DD');\r",
              "pm.environment.set('checkout',checkOut);\r",
              "\r",
              "var additionalNeeds = pm.variables.replaceIn('{{$randomBsBuzz}}');\r",
              "pm.environment.set('aNeeds',additionalNeeds);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var responseBody = pm.response.json();\r",
              "pm.environment.set(\"id\",responseBody.bookingid);\r",
              "\r",
              "pm.test(\"Check the status code is 201\", function (){\r",
              "    pm.expect(pm.response.code).to.eql(201);\r",
              "})\r",
              "\r",
              "pm.test(\"check the response time is less than 200ms\", function (){\r",
              "    pm.expect(pm.response.responseTime).to.be.below(200)\r",
              "})\r",
              "\r",
              "pm.test(\"Check the size of the file size\",function(){\r",
              "    pm.expect(pm.response.responseSize).to.be.below(100000)\r",
              "})\r",
              "\r",
              "pm.test(\"Check the first name as per the response\", function(){\r",
              "    pm.expect(pm.environment.get(\"fName\")).to.eql(responseBody.booking.firstname)\r",
              "})\r",
              "\r",
              "pm.test(\"Check the last name as per the response\", function(){ \r",
              "    pm.expect(pm.environment.get(\"lName\")).to.eql(responseBody.booking.lastname)\r",
              "})\r",
              "\r",
              "pm.test(\"Check the total price as per the response\", function(){ \r",
              "    pm.expect(pm.environment.get(\"tPrice\")).to.eql(responseBody.booking.totalprice.toString())\r",
              "})\r",
              "\r",
              "pm.test(\"Check the deposit paid status as per the response\", function(){\r",
              "    pm.expect(pm.environment.get(\"dPaid\")).to.eql(responseBody.booking.depositpaid.toString())\r",
              "})\r",
              "\r",
              "pm.test(\"Check the booking dates as per the response\",function(){\r",
              "    pm.expect(pm.environment.get(\"checkIn\")).to.eql(responseBody.booking.bookingdates.checkin)\r",
              "})\r",
              "\r",
              "\r",
              "pm.test(\"Check the checkout data as per the checkout date\",function(){\r",
              "    pm.expect(pm.environment.get(\"checkout\")).to.eql(responseBody.booking.bookingdates.checkout)\r",
              "})\r",
              "\r",
              "\r",
              "pm.test(\"Check out the additional needs as par the response\",function(){\r",
              "    pm.expect(pm.environment.get(\"aNeeds\")).to.eql(responseBody.booking.additionalneeds)\r",
              "})\r",
              "\r",
              "pm.test(\"verify the response data format is json\",function(){\r",
              "    pm.response.to.have.jsonBody();\r",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
